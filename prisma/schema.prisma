generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" 
  url      = env("DATABASE_URL")
}

// ─── USUARIO ───────────────────────────
model User {
  id        Int      @id @default(autoincrement())
  username  String?  @unique
  password  String
  name      String
  email     String
  role      String

  tickets   Ticket[]   // ✅ relación con tickets
  posts     Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ─── TICKETS (MEJORADO) ✅
model Ticket {
  id          Int      @id @default(autoincrement())
  nombre      String
  correo      String
  tipo        String
  prioridad   String
  estado      String   @default("Creado")
  descripcion String?

  //  NUEVO
  usuarioId   Int?
  usuario     User? @relation(fields: [usuarioId], references: [id])

  // CHAT
  mensajes    Mensaje[]

  creadoAt    DateTime @default(now())
}

// ─── MENSAJES (CHAT) 
model Mensaje {
  id        Int      @id @default(autoincrement())
  contenido String

  ticketId  Int
  ticket    Ticket @relation(fields: [ticketId], references: [id])

  enviadoPor String  // "usuario" o "soporte"

  creadoAt  DateTime @default(now())
}

// ─── POSTS ───────────────────────────
model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("posts")
}
