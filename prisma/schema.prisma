generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" 
  url      = env("DATABASE_URL")
}

// ─── USUARIO ───────────────────────────
model User {
  id        Int      @id @default(autoincrement())
  username  String?  @unique
  password  String
  name      String
  email     String
  role      String

  tickets   Ticket[]   // relación con tickets
  posts     Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ─── TICKETS (CORREGIDO Y MEJORADO) ───────────────────────────
model Ticket {
  id          Int       @id @default(autoincrement())
  nombre      String
  correo      String
  tipo        String
  prioridad   String
  estado      String    @default("Creado")
  descripcion String?

  // Tiempos de control
  creadoAt    DateTime  @default(now())   // Hora de generación del ticket
  vistoAt     DateTime?                   // Hora en que el asesor lo abrió para revisar

  // Relación con el Usuario/Asesor
  usuarioId   Int?
  usuario     User?     @relation(fields: [usuarioId], references: [id])

  // CHAT
  mensajes    Mensaje[]
}

// ─── MENSAJES (CHAT MEJORADO) ───────────────────────────
model Mensaje {
  id          Int      @id @default(autoincrement())
  contenido   String?  // Opcional por si solo envían un archivo

  // CAMPOS PARA ARCHIVOS MULTIMEDIA
  fileUrl     String?  // Ruta del archivo en el servidor (ej. "/uploads/foto.png")
  fileType    String?  // Tipo: "image", "audio", "document" o null si es solo texto

  ticketId    Int
  ticket      Ticket   @relation(fields: [ticketId], references: [id])

  enviadoPor  String   // "usuario" o "soporte"
  creadoAt    DateTime @default(now())
}

// ─── POSTS ───────────────────────────
model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("posts")
}

// ─── ASIGNACIÓN DE TAREAS IT ───────────────────────────
model Task {
  id        Int      @id @default(autoincrement())
  titulo    String
  encargado String   // Nombre del asesor (ej. "Ana Zepeda")
  correo    String   // Email del asesor asignado para validar su sesión
  area      String   // Area/Departamento IT
  prioridad String   // "Alta", "Media", o "Baja"
  vence     String   // Fecha de vencimiento (ej. "20 Dic 2026")
  createdAt DateTime @default(now())

  @@map("tasks")
}